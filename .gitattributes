# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly handle text files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf
LICENSE text eol=lf
README* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.webm binary
